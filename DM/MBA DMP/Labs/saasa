            }
        ];

        /* --- Global Dynamic Reactive State --- */
        let CLIENT_SHOPPING_CART = [];

        /* ==========================================================================
           DOM ENGINE & LAYOUT RENDERING INTERFACE
           ========================================================================== */
        document.addEventListener("DOMContentLoaded", () => {
            initializeProductCatalogGrid(MASTER_PRODUCT_DATABASE);
            wireUpEventInteractions();
        });

        function wireUpEventInteractions() {
            document.getElementById('cartTriggerBtn').addEventListener('click', toggleCartDisplay);
        }

        function initializeProductCatalogGrid(itemsToRender) {
            const outputContainer = document.getElementById("productGridDisplay");
            outputContainer.innerHTML = "";

            if(itemsToRender.length === 0) {
                outputContainer.innerHTML = `<p style="grid-column: 1/-1; text-align: center; color: var(--text-muted); padding: 40px 0;">No delectable items match your exact filter selection.</p>`;
                return;
            }

            itemsToRender.forEach(product => {
                const cardTemplate = `
                    <div class="product-card" data-product-id="${product.id}">
                        ${product.badge ? `<span class="product-badge">${product.badge}</span>` : ''}
                        <div class="product-image-container">
                            <svg width="100%" height="100%" viewBox="0 0 440 240" xmlns="http://www.w3.org/2000/svg">
                                ${product.svgSeed}
                            </svg>
                        </div>
                        <div class="product-info">
                            <span class="product-category">${product.category}</span>
                            <h3 class="product-title">${product.title}</h3>
                            <p class="product-desc">${product.description}</p>
                            <div class="product-meta">
                                <span class="product-price">$${product.price.toFixed(2)}</span>
                                <button class="add-to-cart-btn" onclick="executeAddToCartRoutine('${product.id}')">
                                    <span>+</span> Add To Basket
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                outputContainer.innerHTML += cardTemplate;
            });
        }

        /* ==========================================================================
           FILTER ACTIONS ENGINE
           ========================================================================== */
        function filterProducts(selectedCategory, contextualButton) {
            // Drop current active button assignment style rules
            document.querySelectorAll(".filter-btn").forEach(btn => btn.classList.remove("active"));
            contextualButton.classList.add("active");

            if (selectedCategory === "all") {
                initializeProductCatalogGrid(MASTER_PRODUCT_DATABASE);
            } else {
                const isolatedItems = MASTER_PRODUCT_DATABASE.filter(item => item.category === selectedCategory);
                initializeProductCatalogGrid(isolatedItems);
            }
        }

        /* ==========================================================================
           RESPONSIVE VIEWPORT LINK SLIDER TOGGLE
           ========================================================================== */
        function toggleMenu() {
            const navElements = document.getElementById("navLinks");
            navElements.classList.toggle("active");
        }

        /* ==========================================================================
           SHOPPING CART STATE UTILITY OPERATIONS
           ========================================================================== */
        function toggleCartDisplay() {
            document.getElementById("cartSidebar").classList.toggle("open");
            document.getElementById("cartOverlay").classList.toggle("open");
        }

        function executeAddToCartRoutine(targetProductId) {
            const sourceDatasetItem = MASTER_PRODUCT_DATABASE.find(item => item.id === targetProductId);
            if (!sourceDatasetItem) return;

            const preExistingCartElement = CLIENT_SHOPPING_CART.find(item => item.id === targetProductId);

            if (preExistingCartElement) {
                preExistingCartElement.quantity += 1;
            } else {
                CLIENT_SHOPPING_CART.push({
                    id: sourceDatasetItem.id,
                    title: sourceDatasetItem.title,
                    price: sourceDatasetItem.price,
                    quantity: 1,
                    category: sourceDatasetItem.category
                });
            }

            renderCartDOMState();
            flashCartCountBadge();
        }

        function changeCartItemQuantity(targetProductId, deltaMagnitude) {
            const stateReferenceItem = CLIENT_SHOPPING_CART.find(item => item.id === targetProductId);
            if (!stateReferenceItem) return;

            stateReferenceItem.quantity += deltaMagnitude;

            if (stateReferenceItem.quantity <= 0) {
                executeRemoveCartItem(targetProductId);
                return;
            }

            renderCartDOMState();
        }

        function executeRemoveCartItem(targetProductId) {
            CLIENT_SHOPPING_CART = CLIENT_SHOPPING_CART.filter(item => item.id !== targetProductId);
            renderCartDOMState();
        }

        function renderCartDOMState() {
            const itemsWrapper = document.getElementById("cartItemsContainer");
            const badgeCountElement = document.getElementById("cartCount");
            const subtotalTextDisplay = document.getElementById("cartSubtotalAmount");

            itemsWrapper.innerHTML = "";
            
            let rollingSumAccumulator = 0;
            let comprehensiveCountAccumulator = 0;

            if (CLIENT_SHOPPING_CART.length === 0) {
                itemsWrapper.innerHTML = `<p class="cart-empty-message">Your pastry basket sits empty. Add tasty items to begin.</p>`;
                badgeCountElement.innerText = "0";
                subtotalTextDisplay.innerText = "$0.00";
                return;
            }

            CLIENT_SHOPPING_CART.forEach(item => {
                const itemFinancialProduct = item.price * item.quantity;
                rollingSumAccumulator += itemFinancialProduct;
                comprehensiveCountAccumulator += item.quantity;

                const elementTemplate = `
                    <div class="cart-item">
                        <div class="cart-item-details">
                            <h4 class="cart-item-name">${item.title}</h4>
                            <div class="cart-item-price">$${item.price.toFixed(2)} each</div>
                            <div class="cart-item-controls">
                                <button class="quantity-btn" onclick="changeCartItemQuantity('${item.id}', -1)">-</button>
                                <span>${item.quantity}</span>
                                <button class="quantity-btn" onclick="changeCartItemQuantity('${item.id}', 1)">+</button>
                            </div>
                        </div>
                        <div style="text-align: right; display: flex; flex-direction: column; gap: 8px;">
                            <span style="font-weight:700; color: var(--text-dark);">$${itemFinancialProduct.toFixed(2)}</span>
                            <button class="remove-item-btn" onclick="executeRemoveCartItem('${item.id}')">Remove</button>
                        </div>
                    </div>
                `;
                itemsWrapper.innerHTML += elementTemplate;
            });

            badgeCountElement.innerText = comprehensiveCountAccumulator;
            subtotalTextDisplay.innerText = `$${rollingSumAccumulator.toFixed(2)}`;
        }

        function flashCartCountBadge() {
            const badge = document.getElementById("cartCount");
            badge.style.transform = "scale(1.4)";
            badge.style.transition = "transform 0.1s ease";
            setTimeout(() => {
                badge.style.transform = "scale(1)";
            }, 150);
        }

        /* ==========================================================================
           TRANSACTION VALIDATION & COMMUNICATIONS INTERFACE
           ========================================================================== */
        function handleFormSubmission(eventLayer) {
            eventLayer.preventDefault();
            alert("Thank you for connecting! Your submission has bypassed verification. A master artisan pastry chef will respond within 2 standard operating hours via email.");
            document.getElementById("bakeryContactForm").reset();
        }

        function processCheckoutSystem() {
            if (CLIENT_SHOPPING_CART.length === 0) {
                alert("Your basket is empty. Add selections from our dynamic pastry listing before verifying secure checkout pathways.");
                return;
            }
            alert(`Order authorized! Total Transaction Amount Value: ${document.getElementById("cartSubtotalAmount").innerText}. Processing bake schedules.`);
            CLIENT_SHOPPING_CART = [];
            renderCartDOMState();
            toggleCartDisplay();
        }
    </script>
