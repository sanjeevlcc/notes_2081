    {
      "id": "g2PHMRoZu3WcQh6-6fD30",
      "type": "text",
      "x": 189.60000610351562,
      "y": 254.60000610351562,
      "width": 561.7523803710938,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ad",
      "roundness": null,
      "seed": 1364325145,
      "version": 9,
      "versionNonce": 612405879,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773806344397,
      "link": null,
      "locked": false,
      "text": "एकचोटी के भयो भने, एउटा huge global shipping company थियो — \n\nनाम थियो KubeSagar Logistics.\n\n\nयो company को काम थियो world भरिका customers को सामान \ncontainers मा pack गरेर सही जहाजमा राख्ने, सही route मा पठाउने, \nर सामान हरायो भने तुरुन्त replace गर्ने.\n\nयो company को whole system लाई भनिन्थ्यो:",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "एकचोटी के भयो भने, एउटा huge global shipping company थियो — \n\nनाम थियो KubeSagar Logistics.\n\n\nयो company को काम थियो world भरिका customers को सामान \ncontainers मा pack गरेर सही जहाजमा राख्ने, सही route मा पठाउने, \nर सामान हरायो भने तुरुन्त replace गर्ने.\n\nयो company को whole system लाई भनिन्थ्यो:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-oxmYLzhelGw3WdPdjRzq",
      "type": "text",
      "x": 192.8000030517578,
      "y": 537.7999877929688,
      "width": 579.6192016601562,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ae",
      "roundness": null,
      "seed": 1904187353,
      "version": 22,
      "versionNonce": 1331770489,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773806344397,
      "link": null,
      "locked": false,
      "text": "Kubernetes Cluster\n\nयस cluster भित्र दुई main parts थिए:\n\n        Control Plane = company ko head office / port headquarters\n\n        Worker Nodes = actual cargo ships",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kubernetes Cluster\n\nयस cluster भित्र दुई main parts थिए:\n\n        Control Plane = company ko head office / port headquarters\n\n        Worker Nodes = actual cargo ships",
      "autoResize": true,
      "lineHeight": 1.25
    },
