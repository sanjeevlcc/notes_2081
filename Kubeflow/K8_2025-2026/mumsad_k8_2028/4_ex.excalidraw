      "seed": 2101036089,
      "version": 90,
      "versionNonce": 560500537,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773806344397,
      "link": null,
      "locked": false,
      "text": "Chapter 3: The Stable Office — Services\n\n\n\n        Port मा एउटा समस्या थियो:\n        \n                ships change हुन्थे\n                cargo move हुन्थ्यो\n                containers restart हुन्थे\n                IP address बदलिन्थ्यो\n\n\n\n    तर customer ले बारम्बार बदलिने \n    address use गर्न सक्दैन.\n\n\n    त्यसैले company ले एउटा \n    stable counter बनायो:\n    \n        Service\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    Technical:\n    \n        A Service provides stable network \n        access to a group of pods.\n    \n            Types:\n            \n                ClusterIP\n                \n                NodePort\n                \n                LoadBalancer\n\n\n\n\n\n\n\n\n\nAnalogy:\n\n    Service = permanent service desk\n\n        Customer ले भन्नु पर्दैन:\n\n            “म pod 10.0.3.9 मा जान्छु”\n\n        Instead:\n\n            “म web-service counter मा जान्छु”\n\n\n\nService ले internally सही pod सम्म traffic पठाउँछ.",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Chapter 3: The Stable Office — Services\n\n\n\n        Port मा एउटा समस्या थियो:\n        \n                ships change हुन्थे\n                cargo move हुन्थ्यो\n                containers restart हुन्थे\n                IP address बदलिन्थ्यो\n\n\n\n    तर customer ले बारम्बार बदलिने \n    address use गर्न सक्दैन.\n\n\n    त्यसैले company ले एउटा \n    stable counter बनायो:\n    \n        Service\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    Technical:\n    \n        A Service provides stable network \n        access to a group of pods.\n    \n            Types:\n            \n                ClusterIP\n                \n                NodePort\n                \n                LoadBalancer\n\n\n\n\n\n\n\n\n\nAnalogy:\n\n    Service = permanent service desk\n\n        Customer ले भन्नु पर्दैन:\n\n            “म pod 10.0.3.9 मा जान्छु”\n\n        Instead:\n\n            “म web-service counter मा जान्छु”\n\n\n\nService ले internally सही pod सम्म traffic पठाउँछ.",
      "autoResize": true,
      "lineHeight": 1.25
    },
