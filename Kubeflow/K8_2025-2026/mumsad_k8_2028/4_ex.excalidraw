    {
      "id": "-oCxKIuCVYNyuGbYHabQ4",
      "type": "text",
      "x": 191.3777737087674,
      "y": 5957.622243245446,
      "width": 737,
      "height": 3050,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 1,
