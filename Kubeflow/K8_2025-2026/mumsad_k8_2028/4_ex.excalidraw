      "seed": 1871998071,
      "version": 35,
      "versionNonce": 293998487,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773806344397,
      "link": null,
      "locked": false,
      "text": "Chapter 6: Deployment = Official Shipping Plan\n\n\n    Customer ले भन्यो:\n    \n        “Mero web app sadhai 3 copies ma chaldai hos.”\n    \n    त्यसका लागि एउटा official plan बनाइयो:\n    \n\n\n\n\n    Deployment\n        Technical:\n        \n            Deployment manages:\n            \n                replicas\n                \n                rollout\n                \n                updates\n                \n                rollback\n\n\n\nAnalogy:\n\n    Deployment = shipping operation contract\n    \n        यसले भन्छ:\n        \n            3 pods चाहिन्छ\n            \n            old version remove गर्दै new version ल्याऊ\n            \n            if failure, rollback गर\n\n\n\n\n\n\nReplicaSet = Count Keeper\n\n    Deployment को तल एउटा count-check गर्ने system हुन्छ:\n\n\n\n    ReplicaSet\n    \n        यसले भन्छ:\n        \n            “Exactly 3 pods running हुनुपर्छ”\n        \n        यदि एक pod crash भयो भने, new one launch गर्छ.\n    \n    \n    \n        Analogy:\n        \n            ReplicaSet = inventory count checker",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Chapter 6: Deployment = Official Shipping Plan\n\n\n    Customer ले भन्यो:\n    \n        “Mero web app sadhai 3 copies ma chaldai hos.”\n    \n    त्यसका लागि एउटा official plan बनाइयो:\n    \n\n\n\n\n    Deployment\n        Technical:\n        \n            Deployment manages:\n            \n                replicas\n                \n                rollout\n                \n                updates\n                \n                rollback\n\n\n\nAnalogy:\n\n    Deployment = shipping operation contract\n    \n        यसले भन्छ:\n        \n            3 pods चाहिन्छ\n            \n            old version remove गर्दै new version ल्याऊ\n            \n            if failure, rollback गर\n\n\n\n\n\n\nReplicaSet = Count Keeper\n\n    Deployment को तल एउटा count-check गर्ने system हुन्छ:\n\n\n\n    ReplicaSet\n    \n        यसले भन्छ:\n        \n            “Exactly 3 pods running हुनुपर्छ”\n        \n        यदि एक pod crash भयो भने, new one launch गर्छ.\n    \n    \n    \n        Analogy:\n        \n            ReplicaSet = inventory count checker",
      "autoResize": true,
      "lineHeight": 1.25
    },
