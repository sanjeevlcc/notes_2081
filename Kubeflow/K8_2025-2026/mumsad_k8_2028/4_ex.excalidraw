    {
      "id": "qbjH92WOeSZdLaHlZbF0M",
      "type": "text",
      "x": 248.60590976910768,
      "y": 25763.061627056264,
      "width": 539,
      "height": 1100,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1v",
      "roundness": null,
      "seed": 671982519,
      "version": 7,
      "versionNonce": 1180183383,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773806344398,
      "link": null,
      "locked": false,
      "text": "Big Revision Table in Words\n\n\n        Cluster = पूरा shipping company\n        \n        Control Plane = head office\n        \n        Node = जहाज / ship\n        \n        Pod = shipment unit\n        \n        Container = cargo box\n        \n        API Server = front desk\n        \n        etcd = master record room\n        \n        Scheduler = cargo placement manager\n        \n        Controller Manager = operations inspector\n        \n        Kubelet = ship captain\n        \n        Container Runtime = crane/engine\n        \n        Kube-proxy = traffic police\n        \n        Service = stable customer counter\n        \n        Namespace = different cargo zones\n        \n        Context = access badge\n        \n        Deployment = shipping plan\n        \n        ReplicaSet = count keeper\n        \n        ConfigMap = instruction paper\n        \n        Secret = locked locker\n        \n        PV = warehouse\n        \n        PVC = storage request form",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Big Revision Table in Words\n\n\n        Cluster = पूरा shipping company\n        \n        Control Plane = head office\n        \n        Node = जहाज / ship\n        \n        Pod = shipment unit\n        \n        Container = cargo box\n        \n        API Server = front desk\n        \n        etcd = master record room\n        \n        Scheduler = cargo placement manager\n        \n        Controller Manager = operations inspector\n        \n        Kubelet = ship captain\n        \n        Container Runtime = crane/engine\n        \n        Kube-proxy = traffic police\n        \n        Service = stable customer counter\n        \n        Namespace = different cargo zones\n        \n        Context = access badge\n        \n        Deployment = shipping plan\n        \n        ReplicaSet = count keeper\n        \n        ConfigMap = instruction paper\n        \n        Secret = locked locker\n        \n        PV = warehouse\n        \n        PVC = storage request form",
      "autoResize": true,
      "lineHeight": 1.25
    },
